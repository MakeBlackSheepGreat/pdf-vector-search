# PDF 向量搜索系统配置
# 复制此文件为 .env 并填入你的实际配置
# API Key 请在 .api_key 文件中配置（复制 .api_key.example 为 .api_key）

# ── API 配置 ──────────────────────────────────────────────
# API Key 已移至 .api_key 文件，此处无需设置
# API Base URL（可选，默认使用硅基流动）
SILICONFLOW_API_BASE=https://api.siliconflow.cn/v1
# 嵌入模型（可选）
EMBEDDING_MODEL=Qwen/Qwen3-VL-Embedding-8B

# ── ChromaDB 配置 ────────────────────────────────────────
# 向量数据库存储路径
CHROMA_DB_PATH=./chroma_db
# 默认集合名称（用于索引和查询）
COLLECTION_NAME=pdf_collection

# ── PDF 配置 ─────────────────────────────────────────────
# 默认 PDF 文件路径（可选，也可通过 --pdf 参数指定）
# PDF_PATH=your-book.pdf

# ── 文本分块配置 ─────────────────────────────────────────
# 分块大小（字符数）。大文件建议 1024，小文件建议 256-512
CHUNK_SIZE=512
# 分块重叠大小
CHUNK_OVERLAP=50

# ── 搜索配置 ─────────────────────────────────────────────
# 默认返回结果数
TOP_K=5

# ── 输出配置 ─────────────────────────────────────────────
# 输出目录
OUTPUT_DIR=./output
